function calculateDistance(lat1: number, lon1: number, lat2: number, lon2: number): number {
  const R = 6371;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;
  const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
    Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
    Math.sin(dLon/2) * Math.sin(dLon/2);
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  return R * c;
}

function formatDistance(km: number, unit: DistanceUnit = 'km'): string {
  if (unit === 'mi') {
    const miles = km * 0.621371;
    if (miles < 0.1) return `${Math.round(miles * 5280)} ft`;
    if (miles < 10) return `${miles.toFixed(1)} mi`;
    return `${Math.round(miles)} mi`;
  }
  if (km < 1) return `${Math.round(km * 1000)} m`;
  if (km < 10) return `${km.toFixed(1)} km`;
  return `${Math.round(km)} km`;
}

export default function TargetScreen() {
  const insets = useSafeAreaInsets();
  const router = useRouter();
  const { targetLocation, setTarget } = useTargetLocation();
  const { t, distanceUnit } = useLanguage();
  
  const [latitudeInput, setLatitudeInput] = useState('');
  const [longitudeInput, setLongitudeInput] = useState('');
  const [nameInput, setNameInput] = useState('');
  const [citySearch, setCitySearch] = useState('');
  
  const [activeTab, setActiveTab] = useState<'nearby' | 'cities' | 'map' | 'coordinates'>('nearby');
  const [mapRegion, setMapRegion] = useState<Region | null>(null);
  const [selectedMapLocation, setSelectedMapLocation] = useState<{ latitude: number; longitude: number } | null>(null);
  
  const [userLocation, setUserLocation] = useState<{ latitude: number; longitude: number } | null>(null);
  const [userCountry, setUserCountry] = useState<string | null>(null);
  const [locationLoading, setLocationLoading] = useState(true);
  const [locationError, setLocationError] = useState<string | null>(null);
  const [isCitySearchFocused, setIsCitySearchFocused] = useState(false);
  const [debouncedCitySearch, setDebouncedCitySearch] = useState('');
  const debounceTimer = useRef<ReturnType<typeof setTimeout> | null>(null);
  const [userCountryCode, setUserCountryCode] = useState<string | null>(null);

  useEffect(() => {
    const getLocation = async () => {
      try {
        if (Platform.OS === 'web') {
          if ('geolocation' in navigator) {
            navigator.geolocation.getCurrentPosition(
              async (position) => {
                const coords = {
                  latitude: position.coords.latitude,
                  longitude: position.coords.longitude,
                };
                setUserLocation(coords);
                try {
                  const response = await fetch(
                    `https://nominatim.openstreetmap.org/reverse?lat=${coords.latitude}&lon=${coords.longitude}&format=json`
                  );
                  const data = await response.json();
                  if (data.address?.country) {
                    setUserCountry(data.address.country);
                    if (data.address?.country_code) {
                      setUserCountryCode(data.address.country_code.toUpperCase());
                    }
                    console.log('User country (web):', data.address.country);
                  }
                } catch (e) {
                  console.log('Reverse geocoding failed (web):', e);
                }
                setLocationLoading(false);
              },
              (error) => {
                console.log('Web geolocation error:', error);
                setLocationError('Could not get location');
                setLocationLoading(false);
              }
            );
          } else {
            setLocationError('Geolocation not supported');
            setLocationLoading(false);
          }
          return;
        }

        const { status } = await ExpoLocation.requestForegroundPermissionsAsync();
        if (status !== 'granted') {
          setLocationError('Location permission denied');
          setLocationLoading(false);
          return;
        }

        const location = await ExpoLocation.getCurrentPositionAsync({
          accuracy: ExpoLocation.Accuracy.Balanced,
        });
        const coords = {
          latitude: location.coords.latitude,
          longitude: location.coords.longitude,
        };
        setUserLocation(coords);

        try {
          const reverseGeocode = await ExpoLocation.reverseGeocodeAsync(coords);
          if (reverseGeocode.length > 0 && reverseGeocode[0].country) {
            setUserCountry(reverseGeocode[0].country);
            if (reverseGeocode[0].isoCountryCode) {
              setUserCountryCode(reverseGeocode[0].isoCountryCode);
            }
            console.log('User country:', reverseGeocode[0].country, reverseGeocode[0].isoCountryCode);
          }
        } catch (e) {
          console.log('Reverse geocoding failed:', e);
        }
        setLocationLoading(false);
      } catch (error) {
        console.error('Error getting location:', error);
        setLocationError('Could not get location');
        setLocationLoading(false);
      }
    };

    getLocation();
  }, []);

  const countryCitiesQuery = useQuery({
    queryKey: ['countryCities', userCountryCode],
    queryFn: () => fetchCitiesByCountry(userCountryCode!, 30),
    enabled: !!userCountryCode && !!userLocation,
    staleTime: 1000 * 60 * 30,
  });

  const countryCities = useMemo(() => {
    if (!userLocation) return [];

    const apiCities = countryCitiesQuery.data ?? [];
    const fallbackCities = apiCities.length > 0 ? apiCities : WORLD_CITIES.filter(city => {
      if (!userCountry) return false;
      const countryNormalized = userCountry.toLowerCase();
      const cityCountry = city.country.toLowerCase();
      return cityCountry === countryNormalized ||
        cityCountry.includes(countryNormalized) ||
        countryNormalized.includes(cityCountry);
    });

    return fallbackCities.map(city => ({
      id: city.id,
      name: city.name,
      latitude: city.latitude,
      longitude: city.longitude,
      description: city.country,
      country: city.country,
      distance: calculateDistance(userLocation.latitude, userLocation.longitude, city.latitude, city.longitude),
      isCity: true as const,
    })).sort((a, b) => a.distance - b.distance);
  }, [userLocation, userCountry, countryCitiesQuery.data]);

  const countryLandmarks = useMemo(() => {
    if (!userCountry || !userLocation) return [];
    
    const countryNormalized = userCountry.toLowerCase();
    return POPULAR_LANDMARKS.filter(loc => {
      const locCountry = loc.country.toLowerCase();
      return locCountry === countryNormalized ||
        locCountry.includes(countryNormalized) ||
        countryNormalized.includes(locCountry);
    }).map(loc => ({
      ...loc,
      distance: calculateDistance(userLocation.latitude, userLocation.longitude, loc.latitude, loc.longitude),
      isCity: false as const,
    })).sort((a, b) => a.distance - b.distance);
  }, [userLocation, userCountry]);

  const nearbyLocations = useMemo(() => {
    if (!userLocation) return POPULAR_LANDMARKS.slice(0, 20).map(loc => ({ ...loc, isCity: false as const }));
    
    if (userCountry && (countryCities.length > 0 || countryLandmarks.length > 0)) {
      return { cities: countryCities.slice(0, 20), landmarks: countryLandmarks.slice(0, 20) };
    }
    
    const withDistance = POPULAR_LANDMARKS.map(loc => ({
      ...loc,
      distance: calculateDistance(userLocation.latitude, userLocation.longitude, loc.latitude, loc.longitude),
      isCity: false as const,
    })).sort((a, b) => (a.distance || 0) - (b.distance || 0)).slice(0, 20);
    
    return { cities: [], landmarks: withDistance };
  }, [userLocation, userCountry, countryCities, countryLandmarks]);

  const handleCitySearchChange = useCallback((text: string) => {
    setCitySearch(text);
    if (debounceTimer.current) {
      clearTimeout(debounceTimer.current);
    }
    debounceTimer.current = setTimeout(() => {
      setDebouncedCitySearch(text);
    }, 400);
  }, []);

  const citySearchQuery = useQuery({
    queryKey: ['citySearch', debouncedCitySearch],
    queryFn: () => searchCitiesApi(debouncedCitySearch, 20),
    enabled: debouncedCitySearch.length >= 2,
    staleTime: 1000 * 60 * 5,
  });

  const filteredCities = citySearchQuery.data ?? [];

  const handlePresetSelect = (location: PopularLocation | Location) => {
    const loc: Location = {
      id: location.id,
      name: location.name,
      latitude: location.latitude,
      longitude: location.longitude,
      description: 'description' in location ? location.description : undefined,
    };
    setTarget(loc);
    router.push('/');
  };

  const handleCitySelect = (city: City | { id: string; name: string; latitude: number; longitude: number; description: string; country: string }) => {
    const loc: Location = {
      id: city.id,
      name: city.name,
      latitude: city.latitude,
      longitude: city.longitude,
      description: 'country' in city ? city.country : undefined,
    };
    setTarget(loc);
    setCitySearch('');
    setIsCitySearchFocused(false);
    router.push('/');
  };

  const handleCoordinateSubmit = () => {
    const lat = parseFloat(latitudeInput);
    const lon = parseFloat(longitudeInput);

    if (isNaN(lat) || isNaN(lon)) {
      Alert.alert(t('target.invalidCoords'), t('target.invalidCoordsMsg'));
      return;
    }

    if (lat < -90 || lat > 90) {
      Alert.alert(t('target.invalidLat'), t('target.invalidLatMsg'));
      return;
    }

    if (lon < -180 || lon > 180) {
      Alert.alert(t('target.invalidLon'), t('target.invalidLonMsg'));
      return;
    }

    const newLocation: Location = {
      id: `custom-${Date.now()}`,
      name: nameInput.trim() || t('target.customLocation'),
      latitude: lat,
      longitude: lon,
    };

    setTarget(newLocation);
    setLatitudeInput('');
    setLongitudeInput('');
    setNameInput('');
    router.push('/');
  };

  const handleReset = () => {
    setTarget(KOTEL);
    router.push('/');
  };

  const handleMapPress = (event: MapPressEvent) => {
    const { latitude, longitude } = event.nativeEvent.coordinate;
    console.log('Map pressed at:', latitude, longitude);
    setSelectedMapLocation({ latitude, longitude });
    
    // Update map region to center on selected location while preserving zoom
    setMapRegion(prev => ({
      latitude,
      longitude,
      latitudeDelta: prev?.latitudeDelta ?? 9,
      longitudeDelta: prev?.longitudeDelta ?? 9,
    }));
  };

  const handleMapLocationConfirm = () => {
    if (!selectedMapLocation) return;
    
    const newLocation: Location = {
      id: `map-${Date.now()}`,
      name: t('target.selectedLocation'),
      latitude: selectedMapLocation.latitude,
      longitude: selectedMapLocation.longitude,
      description: `${selectedMapLocation.latitude.toFixed(4)}°, ${selectedMapLocation.longitude.toFixed(4)}°`,
    };
    setTarget(newLocation);
    setSelectedMapLocation(null);
    router.push('/');
  };

  useEffect(() => {
    if (userLocation && !mapRegion) {
      setMapRegion({
        latitude: userLocation.latitude,
        longitude: userLocation.longitude,
        latitudeDelta: 9,
        longitudeDelta: 9,
      });
    }
  }, [userLocation, mapRegion]);

  return (
    <LinearGradient
      colors={[Colors.compass.backgroundGradientStart, Colors.compass.backgroundGradientEnd]}
      style={styles.container}
    >
      <KeyboardAvoidingView
        style={styles.keyboardView}
        behavior={Platform.OS === 'ios' ? 'padding' : 'height'}
      >
        <ScrollView
          style={styles.scrollView}
          contentContainerStyle={[
            styles.scrollContent,
            { paddingTop: insets.top + 20, paddingBottom: insets.bottom + 20 },
          ]}
          showsVerticalScrollIndicator={false}
          keyboardShouldPersistTaps="handled"
        >
          <View style={styles.header}>
            <Text style={styles.title}>{t('target.title')}</Text>
            <View style={styles.currentTarget}>
              <MapPin size={16} color={Colors.compass.gold} />
              <Text style={styles.currentTargetText}>
                {t('target.current')}: {targetLocation.name}
              </Text>
            </View>
          </View>

          <View style={styles.tabs}>
            {(['nearby', 'cities', 'map', 'coordinates'] as const).map((tab) => (
              <TouchableOpacity
                key={tab}
                style={[styles.tab, activeTab === tab && styles.tabActive]}
                onPress={() => setActiveTab(tab)}
              >
                {tab === 'nearby' && <MapPinned size={14} color={activeTab === tab ? Colors.compass.background : Colors.compass.textSecondary} />}
                {tab === 'cities' && <Building2 size={14} color={activeTab === tab ? Colors.compass.background : Colors.compass.textSecondary} />}
                {tab === 'map' && <Map size={14} color={activeTab === tab ? Colors.compass.background : Colors.compass.textSecondary} />}
                {tab === 'coordinates' && <Navigation size={14} color={activeTab === tab ? Colors.compass.background : Colors.compass.textSecondary} />}
                <Text style={[styles.tabText, activeTab === tab && styles.tabTextActive]}>
                  {t(`target.${tab}`)}
                </Text>
              </TouchableOpacity>
            ))}
          </View>

          {activeTab === 'nearby' && (
            <View style={styles.section}>
              {locationLoading ? (
                <View style={styles.loadingContainer}>
                  <ActivityIndicator size="small" color={Colors.compass.gold} />
                  <Text style={styles.loadingText}>{t('target.gettingLocation')}</Text>
                </View>
              ) : locationError ? (
                <Text style={styles.errorText}>{t('target.locationError')} - {t('target.showingLandmarks')}</Text>
              ) : null}
              
              {'cities' in nearbyLocations && nearbyLocations.cities.length > 0 && (
                <>
                  <Text style={styles.sectionTitle}>
                    {userCountry ? `${t('target.majorCities')} ${userCountry}` : t('target.majorCitiesGeneric')}
                  </Text>
                  {nearbyLocations.cities.map((city) => (
                    <TouchableOpacity
                      key={city.id}
                      style={[
                        styles.presetItem,
                        targetLocation.id === city.id && styles.presetItemActive,
                      ]}
                      onPress={() => handleCitySelect(city)}
                    >
                      <View style={styles.presetInfo}>
                        <View style={styles.presetHeader}>
                          <Building2 size={14} color={Colors.compass.gold} />
                          <Text style={styles.presetName}>{city.name}</Text>
                        </View>
                        <Text style={styles.presetDescription}>{city.description}</Text>
                        {city.distance !== undefined && (
                          <Text style={styles.distanceText}>{formatDistance(city.distance, distanceUnit)} {t('target.away')}</Text>
                        )}
                      </View>
                      {targetLocation.id === city.id && (
                        <Check size={24} color={Colors.compass.gold} />
                      )}
                    </TouchableOpacity>
                  ))}
                </>
              )}
              
              {'landmarks' in nearbyLocations && nearbyLocations.landmarks.length > 0 && (
                <>
                  <Text style={[styles.sectionTitle, nearbyLocations.cities.length > 0 && styles.sectionTitleSpaced]}>
                    {userCountry ? `${t('target.popularPlaces')} ${userCountry}` : t('target.popularPlacesNearby')}
                  </Text>
                  {nearbyLocations.landmarks.map((location) => (
                    <TouchableOpacity
                      key={location.id}
                      style={[
                        styles.presetItem,
                        targetLocation.id === location.id && styles.presetItemActive,
                      ]}
                      onPress={() => handlePresetSelect(location)}
                    >
                      <View style={styles.presetInfo}>
                        <View style={styles.presetHeader}>
                          <MapPin size={14} color={Colors.compass.gold} />
                          <Text style={styles.presetName}>{location.name}</Text>
                        </View>
                        <Text style={styles.presetDescription}>{location.description}</Text>
                        {location.distance !== undefined && (
                          <Text style={styles.distanceText}>{formatDistance(location.distance, distanceUnit)} {t('target.away')}</Text>
                        )}
                      </View>
                      {targetLocation.id === location.id && (
                        <Check size={24} color={Colors.compass.gold} />
                      )}
                    </TouchableOpacity>
                  ))}
                </>
              )}
              
              {!('cities' in nearbyLocations) && Array.isArray(nearbyLocations) && nearbyLocations.map((location) => (
                <TouchableOpacity
                  key={location.id}
                  style={[
                    styles.presetItem,
                    targetLocation.id === location.id && styles.presetItemActive,
                  ]}
                  onPress={() => handlePresetSelect(location)}
                >
                  <View style={styles.presetInfo}>
                    <Text style={styles.presetName}>{location.name}</Text>
                    <Text style={styles.presetDescription}>{location.description}</Text>
                  </View>
                  {targetLocation.id === location.id && (
                    <Check size={24} color={Colors.compass.gold} />
                  )}
                </TouchableOpacity>
              ))}
            </View>
          )}

          {activeTab === 'cities' && (
            <View style={styles.section}>
              <Text style={styles.sectionTitle}>{t('target.searchCities')}</Text>
              <Text style={styles.sectionSubtitle}>{t('target.searchSubtitle')}</Text>
              
              <View style={styles.searchContainer}>
                <Search size={18} color={Colors.compass.textSecondary} />
                <TextInput
                  style={styles.searchInput}
                  value={citySearch}
                  onChangeText={handleCitySearchChange}
                  placeholder={t('target.searchPlaceholder')}
                  placeholderTextColor={Colors.compass.textSecondary}
                  autoCapitalize="none"
                  autoCorrect={false}
                  onFocus={() => setIsCitySearchFocused(true)}
                />
              </View>

              {citySearch.length > 0 && citySearch.length < 2 && (
                <Text style={styles.hintText}>{t('target.enterMore').replace('{count}', String(2 - citySearch.length)).replace('{plural}', 2 - citySearch.length > 1 ? 's' : '')}</Text>
              )}

              {citySearchQuery.isLoading && debouncedCitySearch.length >= 2 && (
                <View style={styles.searchLoadingContainer}>
                  <ActivityIndicator size="small" color={Colors.compass.gold} />
                  <Text style={styles.searchLoadingText}>{t('target.searchingCities')}</Text>
                </View>
              )}

              {filteredCities.length > 0 && isCitySearchFocused && (
                <View style={styles.citiesList}>
                  {filteredCities.map((city) => (
                    <TouchableOpacity
                      key={city.id}
                      style={[
                        styles.cityItem,
                        targetLocation.id === city.id && styles.cityItemActive,
                      ]}
                      onPress={() => handleCitySelect(city)}
                    >
                      <View style={styles.cityInfo}>
                        <Text style={styles.cityName}>{city.name}</Text>
                        <Text style={styles.cityCountry}>{city.country}</Text>
                      </View>
                      {targetLocation.id === city.id && (
                        <Check size={20} color={Colors.compass.gold} />
                      )}
                    </TouchableOpacity>
                  ))}
                </View>
              )}

              {debouncedCitySearch.length >= 2 && !citySearchQuery.isLoading && filteredCities.length === 0 && (
                <Text style={styles.noResultsText}>{t('target.noResults')} &quot;{debouncedCitySearch}&quot;</Text>
              )}
            </View>
          )}

          {activeTab === 'map' && (
            <View style={styles.section}>
              <Text style={styles.sectionTitle}>{t('target.selectOnMap')}</Text>
              <Text style={styles.sectionSubtitle}>{t('target.mapSubtitle')}</Text>
              
              <View style={styles.mapContainer}>
                {locationLoading ? (
                  <View style={styles.mapLoadingContainer}>
                    <ActivityIndicator size="large" color={Colors.compass.gold} />
                    <Text style={styles.mapLoadingText}>{t('target.gettingLocation')}</Text>
                  </View>
                ) : (
                  <NativeMapView
                    userLocation={userLocation}
                    mapRegion={mapRegion}
                    targetLocation={targetLocation}
                    selectedMapLocation={selectedMapLocation}
                    onMapPress={handleMapPress}
                  />
                )}
              </View>
              
              {selectedMapLocation && (
                <View style={styles.selectedLocationInfo}>
                  <View style={styles.selectedCoords}>
                    <Text style={styles.selectedCoordsLabel}>{t('target.selected')}</Text>
                    <Text style={styles.selectedCoordsValue}>
                      {selectedMapLocation.latitude.toFixed(4)}°, {selectedMapLocation.longitude.toFixed(4)}°
                    </Text>
                  </View>
                  <TouchableOpacity style={styles.confirmMapButton} onPress={handleMapLocationConfirm}>
                    <Check size={20} color={Colors.compass.background} />
                    <Text style={styles.confirmMapButtonText}>{t('target.setAsTarget')}</Text>
                  </TouchableOpacity>
                </View>
              )}
              
              <View style={styles.mapHint}>
                <Text style={styles.mapHintText}>• {t('target.pinchZoom')}</Text>
                <Text style={styles.mapHintText}>• {t('target.dragPan')}</Text>
                <Text style={styles.mapHintText}>• {t('target.bluePin')}</Text>
                <Text style={styles.mapHintText}>• {t('target.goldPin')}</Text>
              </View>
            </View>
          )}

          {activeTab === 'coordinates' && (
            <View style={styles.section}>
              <Text style={styles.sectionTitle}>{t('target.enterCoordinates')}</Text>
              
              <View style={styles.inputGroup}>
                <Text style={styles.inputLabel}>{t('target.locationName')}</Text>
                <TextInput
                  style={styles.input}
                  value={nameInput}
                  onChangeText={setNameInput}
                  placeholder={t('target.locationNamePlaceholder')}
                  placeholderTextColor={Colors.compass.textSecondary}
                />
              </View>

              <View style={styles.inputRow}>
                <View style={[styles.inputGroup, { flex: 1 }]}>
                  <Text style={styles.inputLabel}>{t('target.latitude')}</Text>
                  <TextInput
                    style={styles.input}
                    value={latitudeInput}
                    onChangeText={setLatitudeInput}
                    placeholder="e.g., 31.7781"
                    placeholderTextColor={Colors.compass.textSecondary}
                    keyboardType="numbers-and-punctuation"
                  />
                  <Text style={styles.inputHint}>{t('target.latRange')}</Text>
                </View>
                <View style={[styles.inputGroup, { flex: 1 }]}>
                  <Text style={styles.inputLabel}>{t('target.longitude')}</Text>
                  <TextInput
                    style={styles.input}
                    value={longitudeInput}
                    onChangeText={setLongitudeInput}
                    placeholder="e.g., 35.2354"
                    placeholderTextColor={Colors.compass.textSecondary}
                    keyboardType="numbers-and-punctuation"
                  />
                  <Text style={styles.inputHint}>{t('target.lonRange')}</Text>
                </View>
              </View>

              <TouchableOpacity style={styles.submitButton} onPress={handleCoordinateSubmit}>
                <Navigation size={20} color={Colors.compass.background} />
                <Text style={styles.submitButtonText}>{t('target.setAsTarget')}</Text>
              </TouchableOpacity>
            </View>
          )}

          <TouchableOpacity style={styles.resetButton} onPress={handleReset}>
            <RotateCcw size={18} color={Colors.compass.textSecondary} />
            <Text style={styles.resetButtonText}>{t('target.resetToKotel')}</Text>
          </TouchableOpacity>
        </ScrollView>
      </KeyboardAvoidingView>
    </LinearGradient>
  );
}

