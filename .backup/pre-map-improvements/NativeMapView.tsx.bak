import React, { useRef } from 'react';
import { StyleSheet, View, ActivityIndicator } from 'react-native';
import { WebView } from 'react-native-webview';
import Colors from '@/constants/colors';
import { Location } from '@/constants/locations';
import type { Region, MapPressEvent } from 'react-native-maps';

interface NativeMapViewProps {
  userLocation: { latitude: number; longitude: number } | null;
  mapRegion: Region | null;
  targetLocation: Location;
  selectedMapLocation: { latitude: number; longitude: number } | null;
  onMapPress: (event: MapPressEvent) => void;
}

export default function NativeMapView({
  userLocation,
  mapRegion,
  targetLocation,
  selectedMapLocation,
  onMapPress,
}: NativeMapViewProps) {
  const webViewRef = useRef<WebView>(null);
  
  const lat = mapRegion?.latitude || userLocation?.latitude || 31.7767;
  const lng = mapRegion?.longitude || userLocation?.longitude || 35.2345;
  
  // Convert latitudeDelta to zoom level (approximate)
  const latDelta = mapRegion?.latitudeDelta ?? 9;
  const zoom = Math.round(Math.log2(360 / latDelta));

  const handleMessage = (event: { nativeEvent: { data: string } }) => {
    try {
      const data = JSON.parse(event.nativeEvent.data);
      if (data.type === 'mapClick') {
        onMapPress({
          nativeEvent: {
            coordinate: {
              latitude: data.lat,
              longitude: data.lng,
            },
          },
        } as MapPressEvent);
      }
    } catch (e) {
      console.log('WebView message parse error:', e);
    }
  };

  const mapHtml = `
    <!DOCTYPE html>
    <html>
    <head>
      <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; }
        #map { width: 100%; height: 100%; }
        .leaflet-control-attribution { font-size: 8px !important; }
      </style>
    </head>
    <body>
      <div id="map"></div>
      <script>
        var map = L.map('map', {
          zoomControl: true,
          attributionControl: true
        }).setView([${lat}, ${lng}], ${zoom});
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '© OpenStreetMap'
        }).addTo(map);
        
        var targetIcon = L.divIcon({
          className: 'custom-marker',
          html: '<div style="width:24px;height:24px;background:#4A90D9;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:2px solid white;box-shadow:0 2px 5px rgba(0,0,0,0.3);"></div>',
          iconSize: [24, 24],
          iconAnchor: [12, 24]
        });
        
        var selectedIcon = L.divIcon({
          className: 'custom-marker',
          html: '<div style="width:24px;height:24px;background:#D4AF37;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:2px solid white;box-shadow:0 2px 5px rgba(0,0,0,0.3);"></div>',
          iconSize: [24, 24],
          iconAnchor: [12, 24]
        });
        
        var targetMarker = L.marker([${targetLocation.latitude}, ${targetLocation.longitude}], {icon: targetIcon})
          .addTo(map)
          .bindPopup('${targetLocation.name.replace(/'/g, "\\'")}<br>Current target');
        
        var selectedMarker = null;
        ${selectedMapLocation ? `
          selectedMarker = L.marker([${selectedMapLocation.latitude}, ${selectedMapLocation.longitude}], {icon: selectedIcon})
            .addTo(map)
            .bindPopup('Selected location');
        ` : ''}
        
        ${userLocation ? `
          var userIcon = L.divIcon({
            className: 'user-marker',
            html: '<div style="width:16px;height:16px;background:#007AFF;border-radius:50%;border:3px solid white;box-shadow:0 2px 5px rgba(0,0,0,0.3);"></div>',
            iconSize: [16, 16],
            iconAnchor: [8, 8]
          });
          L.marker([${userLocation.latitude}, ${userLocation.longitude}], {icon: userIcon})
            .addTo(map)
            .bindPopup('Your location');
        ` : ''}
        
        map.on('click', function(e) {
          window.ReactNativeWebView.postMessage(JSON.stringify({
            type: 'mapClick',
            lat: e.latlng.lat,
            lng: e.latlng.lng
          }));
          
          if (selectedMarker) {
            map.removeLayer(selectedMarker);
          }
          selectedMarker = L.marker([e.latlng.lat, e.latlng.lng], {icon: selectedIcon})
            .addTo(map)
            .bindPopup('Selected location');
        });
      </script>
    </body>
    </html>
  `;

  return (
    <View style={styles.container}>
      <WebView
        ref={webViewRef}
        source={{ html: mapHtml }}
        style={styles.map}
        onMessage={handleMessage}
        javaScriptEnabled={true}
        domStorageEnabled={true}
        startInLoadingState={true}
        renderLoading={() => (
          <View style={styles.loading}>
            <ActivityIndicator size="large" color={Colors.compass.gold} />
          </View>
        )}
        scrollEnabled={false}
        bounces={false}
        originWhitelist={['*']}
      />
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
  },
  map: {
    flex: 1,
  },
  loading: {
    position: 'absolute',
    top: 0,
    left: 0,
    right: 0,
    bottom: 0,
    justifyContent: 'center',
    alignItems: 'center',
    backgroundColor: Colors.compass.cardBackground,
  },
});
